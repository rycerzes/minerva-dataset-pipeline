# ── LLM Provider (required for LLM augmentation stages) ──────────────
# Model prefix follows LiteLLM convention: provider/model-name
# Examples:
#   openai/gpt-4o          openai/gpt-4o-mini
#   anthropic/claude-3-haiku
#   groq/llama-3.1-70b
#   azure/gpt-4o
#   openrouter/openai/gpt-4o
LITELLM_API_BASE_URL=
LITELLM_API_KEY=
LITELLM_MODEL=
LITELLM_TEMPERATURE=0.7
LITELLM_MAX_TOKENS=4096
LITELLM_RPM=60

# ── HuggingFace (optional — needed for the-stack-smol code comments) ──
# The dataset is public so it usually works without a token for small fetches.
# Generate at: https://huggingface.co/settings/tokens
# HF_API_TOKEN=
